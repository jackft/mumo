{
  "name": "@mumo/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./kernel": "./src/kernel.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./kernel": {
        "types": "./dist/kernel.d.ts",
        "default": "./dist/kernel.js"
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "node-interval-tree": "^2.1.2",
    "prosemirror-model": "^1.25.9",
    "prosemirror-state": "^1.4.4",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}

{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["packages/mumo/public/ort-wasm-simd-threaded.jsep.mjs"],
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "packages/*": {},
    "packages/mumo": {
      "entry": [],
      "ignore": []

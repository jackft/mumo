    <ANNOTATION>
      <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
        <ANNOTATION_VALUE>yeah I think the weather has been really strange lately</ANNOTATION_VALUE>
      </ALIGNABLE_ANNOTATION>
